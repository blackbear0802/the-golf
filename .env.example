# 더 골프 여행 플랫폼 — 환경변수 가이드
# 이 파일을 복사해서 .env.local로 사용하세요
# cp .env.example .env.local

# ── 데이터베이스 ──────────────────────────────────
# Supabase: https://supabase.com/dashboard/project/<id>/settings/database
# Railway:  https://railway.app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/thegolf?schema=public"

# ── NextAuth ──────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ── Kakao OAuth ───────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ── Naver OAuth ───────────────────────────────────
# https://developers.naver.com/apps/#/register
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ── Kakao 알림톡 ─────────────────────────────────
# https://business.kakao.com → 비즈니스 채널 → 알림톡
KAKAO_ALIMTALK_API_KEY=""
KAKAO_ALIMTALK_SENDER_KEY=""

# ── Naver Band API ────────────────────────────────
# band_api_연동가이드_v1.0.docx 참고
# 상업적 사용 허가 확인 필요 (TODOS.md 참고)
BAND_ACCESS_TOKEN=""
BAND_BAND_KEY=""

# ── AI (Claude) ───────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""

# ── Object Storage (이미지) ───────────────────────
# Cloudflare R2 권장 (S3 호환, egress 무료)
# 또는 AWS S3
STORAGE_ENDPOINT=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME="thegolf-images"
STORAGE_PUBLIC_URL=""

# ── 내부 설정 ─────────────────────────────────────
# 예약 미배정 알림 임계값 (시간)
BOOKING_UNASSIGNED_ALERT_HOURS=48

# 알림 재시도 최대 횟수
NOTIFICATION_MAX_RETRIES=3
